{
  "name": "beautifuljekyll",
  "version": "1.0.0",
  "description": "Beautiful Jekyll 博客主题",
  "private": true,
  "engines": {
    "node": ">=18.0.0 <19.0.0",
    "npm": ">=9.0.0 <10.0.0"
  },
  "scripts": {
    "build": "bundle install && bundle exec jekyll build",
    "build:prod": "JEKYLL_ENV=production bundle exec jekyll build",
    "build:cf": "bundle exec jekyll build",
    "serve": "bundle exec jekyll serve",
    "clean": "bundle exec jekyll clean",
    "deploy:netlify": "netlify deploy --prod --build",
    "deploy:vercel": "vercel --prod",
    "deploy:firebase": "firebase deploy --only hosting",
    "pages:dev": "wrangler pages dev ./_site",
    "pages:deploy": "npm run build:prod && wrangler pages deploy ./_site",
    "pages:deploy:preview": "npm run build && wrangler pages deploy ./_site --env preview",
    "pages:deploy:production": "npm run build:prod && wrangler pages deploy ./_site --env production",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/694426204/-beautifuljekyll.git"
  },
  "keywords": [
    "jekyll",
    "blog",
    "static-site"
  ],
  "author": "苍雪",
  "license": "MIT"
}